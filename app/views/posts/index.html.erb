<h1>Posts</h1>

<table class="table table-striped table-hover">
  <thead class="table-dark">
    <tr>
      <th>Title</th>
      <th>Difficulty</th>
      <th>Type Of Meal</th>
      <th>Cuisine</th>
      <th>User</th>
      <th><%= link_to 'Date', posts_path(sort_by: 'date') %></th>
      <th><%= link_to 'Sweets', posts_path(sort_by: 'likes') %></th>
    </tr>
  </thead>
  <tbody>
    <% @posts.each do |post| %>
      <tr>
        <td><%= link_to post.title, post_path(post) %></td>
        <td><%= post.difficulty %></td>
        <td><%= post.meal %></td>
        <td><%= post.cuisine %></td>
        <td><%= post.user.email %></td>
        <td><%= post.created_at.strftime("%B %d, %Y") %></td>
        <td><%= pluralize(post.likes.count, 'Sweet') %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<p>
  <%= link_to "Create New Post", new_post_path, class: 'btn btn-primary' %>
</p>
