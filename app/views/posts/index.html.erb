<h1>Posts</h1>

<table class="table table-striped table-hover">
  <thead class="table-dark">
    <tr>
        <th>Post</th>
        <th>Difficulty</th>
        <th>Type Of Meal</th>
        <th>Cuisine</th>
        <th>User</th>
        <th>Sweets</th>
        <th></th>
    </tr>
  </thead>
  <tbody>
  <% @posts.each do |post| %>
    <tr>
      <td><%= post.title %></td>
      <td><%= post.difficulty %></td>
      <td><%= post.meal %></td>
      <td><%= post.cuisine %></td>
      <td><%= post.user.email %></td>
      <td><%= pluralize(post.likes.count, 'Sweet') %></td>
      <td><%= link_to 'Meal Details', post_path(post), class: 'btn btn-outline-secondary' %></td>
    </tr>
  <% end %>
</tbody>
</table>

<p>
  <%= link_to "Create New Post", new_post_path, class: 'btn btn-primary' %>
</p>
