<h1>Edit Your Business Page</h1>

<%= form_with(model: [ @user, @business ], local: true) do |form| %>
  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>
  <div>
    <%= form.label :address %>
    <%= form.text_field :address %>
  </div>
  <div>
    <%= form.label :restaurant_type %>
    <%= form.text_field :restaurant_type %>
  </div>
  <div>
    <%= form.label :bio %>
    <%= form.text_area :bio %>
  </div>
  <div>
    <%= form.label :menu, 'Menu (Please list your items)' %>
    <%= form.text_area :menu %>
  </div>
  <div>
    <%= form.submit "Update Business Page" %>
  </div>
<% end %>

<%= link_to 'Back to Business Page', user_business_path(@user) %>

