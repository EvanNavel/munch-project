<h1>Posts</h1>

 

<table class="table table-striped table-hover">

 

  <thead class="table-dark">

    <tr>

        <th>Post</th>
        <th>Difficulty</th>
        <th>Type Of Meal</th>
        <th>Cuisine</th>
        <th>Creator</th>
        <th>Details</th>

    </tr>

  </thead>

 

  <tbody>

    <% @posts.each do |p| %>

      <tr>

        <td><%= p.title %></td>
        <td><%= p.difficulty %></td>
        <td><%= p.meal %></td>
        <td><%= p.cuisine %></td>
        <td><%= p.user.email %></td>
        <td><%= link_to 'Meal Details', show_posts_path(p), class: 'btn btn-outline-secondary' %>


      </tr>

    <% end %>

  </tbody>
</table>