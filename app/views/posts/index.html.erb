<h1>Activity</h1>

 

<table class="table table-striped table-hover">

 

  <thead class="table-dark">

    <tr>

      <th>Post</th>

    </tr>

  </thead>

 

  <tbody>

    <% @posts.each do |p| %>

      <tr>

        <td><%= p.title %></td>
        <td><%= p.body %></td>

      </tr>

    <% end %>

  </tbody>
</table>

<p>

  <%= link_to 'Back to Home Page', home_path, class: 'btn btn-outline-secondary' %>

</p>