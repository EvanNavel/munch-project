<h1>Create New Post</h1>
 
<%= bootstrap_form_with model: @post, url: posts_path, method: :post, data: { turbo: false } do |f| %>
 
  <%= f.text_field :title %>
  <%= f.text_area :body %>
  <%= f.text_field :meal %>
  <%= f.text_field :difficulty %>
  <%= f.text_field :cuisine %>
  <%= f.submit %>
 
<% end %>