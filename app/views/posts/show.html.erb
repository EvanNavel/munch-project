<h1><%= @post.title %></h1>

<div class="sweets-counter">
  <strong><%= pluralize(@post.likes.count, 'Sweet') %></strong>
</div>

<% if current_user %>
  <% if @post.liked_by?(current_user) %>
    <%= button_to 'Unsweet', post_like_path(@post), method: :delete, class: 'btn btn-warning' %>
  <% else %>
    <%= button_to 'Sweet', post_like_path(@post), method: :post, class: 'btn btn-success' %>
  <% end %>
<% end %>

<ul>
 <br>
    <li> <%= @post.user.email %></li>
    <br>
    <li><%= @post.difficulty %></li>
    <br>
    <li><%= @post.cuisine %></li>
    <br>
    <li><%= @post.meal %></li>
    <br>
</ul>

<h2> Recipe </h2>

<p><%= @post.body%></p>

<% if @post.favorited_by?(current_user) %>
  <%= button_to 'Remove from Cookbook', post_favorite_path(@post), method: :delete, class: 'btn btn-warning' %>
<% else %>
  <%= button_to 'Add to Cookbook', post_favorite_path(@post), method: :post, class: 'btn btn-success' %>
<% end %>

<a><%= link_to 'Back To Posts', posts_path, class: 'btn btn-outline-secondary' %></a>
